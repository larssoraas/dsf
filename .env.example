# PostgreSQL
POSTGRES_DB=torget
POSTGRES_USER=torget
POSTGRES_PASSWORD=torget_secret
DATABASE_URL=postgresql://torget:torget_secret@localhost:5432/torget

# JWT
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET_DO_NOT_USE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=listing-images
MINIO_PUBLIC_URL=http://localhost:9000/listing-images

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
