{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@torget/shared": ["../../packages/shared/index.ts"]
    }
  },
  "include": ["src", "drizzle"],
  "exclude": ["node_modules", "dist"]
}
